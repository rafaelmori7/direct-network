{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/listas", "destination": "/listas.html" },
    { "source": "/listas/:path*", "destination": "/lista.html" },
    { "source": "/eventos/:path*", "destination": "/evento.html" },
    { "source": "/quem-somos", "destination": "/quem-somos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}

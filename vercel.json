{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/eventos/(.*)", "dest": "/evento.html" },
    { "src": "/listas/(.*)", "dest": "/lista.html" },
    { "src": "/listas", "dest": "/listas.html" },
    { "src": "/quem-somos", "dest": "/quem-somos.html" },
    { "src": "/404", "dest": "/404.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
